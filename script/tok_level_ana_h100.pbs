#!/bin/bash
#PBS -P jp09
#PBS -q gpuhopper
#PBS -l ngpus=1
#PBS -l ncpus=12
#PBS -l mem=48GB
#PBS -l walltime=01:00:00
#PBS -l storage=scratch/jp09+gdata/hn98
#PBS -j oe
#PBS -V

set -euo pipefail

if [[ -n "${PBS_O_WORKDIR:-}" ]]; then
  cd "$PBS_O_WORKDIR"
else
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  cd "$(cd "$SCRIPT_DIR/.." && pwd)"
fi

mkdir -p logs
JOB_TAG="${PBS_JOBID:-local_$(date +%Y%m%d_%H%M%S)}"
LOG_FILE="logs/tok_level_ana_${JOB_TAG}.log"
exec > >(tee -a "$LOG_FILE") 2>&1

source /scratch/jp09/dd9648/venvs/dflash_h100/bin/activate
unset PYTHONPATH
export HF_HOME=/scratch/jp09/dd9648/.cache/huggingface
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export HF_DATASETS_OFFLINE=1
export CUDA_LAUNCH_BLOCKING=0
export PYTHONFAULTHANDLER=1
mkdir -p "$HF_HOME"

echo "=== Environment ==="
echo "Job ID: ${PBS_JOBID:-local}"
echo "Node: $(hostname)"
python - <<'PY'
import torch
print('torch', torch.__version__, 'cuda', torch.version.cuda, 'cxx11abi', torch.compiled_with_cxx11_abi())
try:
    import flash_attn
    print('flash_attn', flash_attn.__version__)
except Exception as exc:
    print('flash_attn unavailable:', exc)
PY

echo ""

MODEL_NAME="${MODEL_NAME:-Qwen/Qwen3-4B}"
DRAFT_NAME="${DRAFT_NAME:-z-lab/Qwen3-4B-DFlash-b16}"
DATASET="${DATASET:-gsm8k}"
BLOCK_SIZE="${BLOCK_SIZE:-16}"
MAX_SAMPLES="${MAX_SAMPLES:-32}"
MAX_NEW_TOKENS="${MAX_NEW_TOKENS:-512}"
TEMPERATURE="${TEMPERATURE:-0.0}"
CD_ALPHA="${CD_ALPHA:-0.6}"
CD_BETA="${CD_BETA:-0.0}"
NEG_DROPOUT="${NEG_DROPOUT:-0.3}"
NEG_NOISE_STD="${NEG_NOISE_STD:-0.0}"
NEG_HIDDEN_MODE="${NEG_HIDDEN_MODE:-mask_zero}"
SHADOW_NUM_SAMPLES="${SHADOW_NUM_SAMPLES:-1}"
MAX_EXAMPLE_ROWS="${MAX_EXAMPLE_ROWS:-20}"
REPORT_DIR="${REPORT_DIR:-analysis/results/tok_level_ana_${JOB_TAG}}"
NO_PLOTS="${NO_PLOTS:-1}"
DETERMINISTIC="${DETERMINISTIC:-0}"
TOP64_MASK_MODE="${TOP64_MASK_MODE:-0}"
SEED="${SEED:-42}"

echo "=== Analysis Configuration ==="
echo "MODEL_NAME      : $MODEL_NAME"
echo "DRAFT_NAME      : $DRAFT_NAME"
echo "DATASET         : $DATASET"
echo "BLOCK_SIZE      : $BLOCK_SIZE"
echo "MAX_SAMPLES     : $MAX_SAMPLES"
echo "MAX_NEW_TOKENS  : $MAX_NEW_TOKENS"
echo "TEMPERATURE     : $TEMPERATURE"
echo "CD_ALPHA        : $CD_ALPHA"
echo "CD_BETA         : $CD_BETA"
echo "NEG_DROPOUT     : $NEG_DROPOUT"
echo "NEG_NOISE_STD   : $NEG_NOISE_STD"
echo "NEG_HIDDEN_MODE : $NEG_HIDDEN_MODE"
echo "SHADOW_SAMPLES  : $SHADOW_NUM_SAMPLES"
echo "REPORT_DIR      : $REPORT_DIR"
echo "NO_PLOTS        : $NO_PLOTS"
echo "DETERMINISTIC   : $DETERMINISTIC"
echo "TOP64_MASK_MODE : $TOP64_MASK_MODE"
echo "SEED            : $SEED"
echo ""

CMD=(
  python -m analysis.tok_level_ana
  --model-name-or-path "$MODEL_NAME"
  --draft-name-or-path "$DRAFT_NAME"
  --dataset "$DATASET"
  --block-size "$BLOCK_SIZE"
  --max-samples "$MAX_SAMPLES"
  --max-new-tokens "$MAX_NEW_TOKENS"
  --temperature "$TEMPERATURE"
  --cd-alpha "$CD_ALPHA"
  --cd-beta "$CD_BETA"
  --negative-context-dropout "$NEG_DROPOUT"
  --negative-context-noise-std "$NEG_NOISE_STD"
  --negative-hidden-mode "$NEG_HIDDEN_MODE"
  --cd-shadow-num-samples "$SHADOW_NUM_SAMPLES"
  --max-example-rows "$MAX_EXAMPLE_ROWS"
  --report-dir "$REPORT_DIR"
  --seed "$SEED"
)

if [[ "$DETERMINISTIC" == "1" ]]; then
  CMD+=(--deterministic)
else
  CMD+=(--no-deterministic)
fi

if [[ "$NO_PLOTS" == "1" ]]; then
  CMD+=(--no-plots)
fi

if [[ "$TOP64_MASK_MODE" == "1" ]]; then
  CMD+=(--top64-mask-mode)
else
  CMD+=(--no-top64-mask-mode)
fi

echo "=== Launching analysis ==="
printf ' %q' "${CMD[@]}"
echo ""
"${CMD[@]}"

echo ""
echo "=== Analysis completed at $(date) ==="
echo "Report directory: $REPORT_DIR"
